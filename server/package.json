{
  "name": "@ai-hype/server",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && cp src/landing.html dist/landing.html",
    "start": "node dist/index.js",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --passWithNoTests",
    "test:engine": "NODE_OPTIONS='--experimental-vm-modules' jest --testPathPattern=engine",
    "test:api": "NODE_OPTIONS='--experimental-vm-modules' jest --testPathPattern=routes",
    "test:session": "NODE_OPTIONS='--experimental-vm-modules' jest --testPathPattern=session",
    "test:ws": "NODE_OPTIONS='--experimental-vm-modules' jest --testPathPattern=handler",
    "test:db": "NODE_OPTIONS='--experimental-vm-modules' jest --testPathPattern=db/index",
    "test:all": "NODE_OPTIONS='--experimental-vm-modules' jest"
  },
  "dependencies": {
    "@ai-hype/shared": "*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@supabase/supabase-js": "^2.39.0",
    "bcryptjs": "^2.4.3",
    "break_eternity.js": "^2.1.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "uuid": "^9.0.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.5",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
